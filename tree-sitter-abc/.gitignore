# Build / dependency artifacts — the GENERATED parser under src/ IS committed
# (tree-sitter convention), but downstream build outputs are not.
node_modules/
package-lock.json
*.wasm
*.o
*.obj
*.so
*.dylib
*.dll
build/
dist/
.build/
target/

# ...but DO commit the few WASM files the web/WASM reuse proof needs (stage G3):
#   - the grammar wasm (the headline reuse artifact; ~26 KB, self-contained demo)
#   - the demo's self-contained copy of it
#   - the vendored web-tree-sitter runtime (offline demo, version-pinned 0.26.9)
!tree-sitter-abc.wasm
!web/tree-sitter-abc.wasm
!web/vendor/web-tree-sitter.wasm
